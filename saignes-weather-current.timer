[Unit]
Description=Run saignes-weather-current hourly, at :30 past the hour (offset from saignes-weather.timer's :00 so the two never write weather_cache.json at the same moment)
Requires=saignes-weather-current.service

[Timer]
OnCalendar=*-*-* *:30:00
RandomizedDelaySec=30
Persistent=true

[Install]
WantedBy=timers.target
